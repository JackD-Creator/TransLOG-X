# TransLOG-X — Environment Variables
# Copy file ini ke .env dan isi dengan nilai yang benar
# JANGAN commit file .env ke Git

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database (untuk migration tools saja, jangan di frontend)
DATABASE_URL=postgresql://postgres.your-ref:your-password@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres

# App
NUXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NUXT_PUBLIC_SUPABASE_KEY=${SUPABASE_ANON_KEY}
